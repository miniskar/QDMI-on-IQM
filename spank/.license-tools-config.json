{
  "author": {
    "name": "IQM Finland Oy",
    "years": [2026]
  },
  "force_author": true,
  "license": "GPL-3.0-or-later",
  "force_license": true,
  "title": false,
  "include": ["**/*"],
  "style_override_for_suffix": {
    ".pyi": "DOCSTRING_STYLE",
    ".in": "POUND_STYLE",
    ".mlir": "SLASH_STYLE",
    ".td": "SLASH_STYLE",
    ".yaml": "POUND_STYLE",
    ".toml": "POUND_STYLE",
    ".proto": "SLASH_STYLE",
    ".ts": "C_STYLE",
    ".ps1": "POUND_STYLE",
    "Dockerfile": "POUND_STYLE"
  },
  "exclude": [
    "^\\.[^/]+",
    "/\\.[^/]+",
    ".*\\.qasm",
    ".*\\.ll",
    ".*\\.md",
    ".*\\.bib",
    ".*\\.cff",
    ".*\\.css",
    ".*\\.json",
    ".*\\.html",
    ".*\\.tfc",
    ".*\\.qc",
    ".*\\.real",
    ".*\\.tex",
    "uv\\.lock",
    "py\\.typed",
    ".*build.*"
  ]
}
